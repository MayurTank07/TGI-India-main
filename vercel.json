{
  "headers": [
    {
      "source": "/admin",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/service",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/service/(.*)",
      "destination": "/services/$1",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/services.html",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/services/it.html",
      "destination": "/services/it",
      "permanent": true
    },
    {
      "source": "/services/bpo.html",
      "destination": "/services/bpo",
      "permanent": true
    },
    {
      "source": "/services/non-it.html",
      "destination": "/services/non-it",
      "permanent": true
    },
    {
      "source": "/services/accounting.html",
      "destination": "/services/accounting",
      "permanent": true
    },
    {
      "source": "/services/healthcare.html",
      "destination": "/services/healthcare",
      "permanent": true
    },
    {
      "source": "/services/corporate.html",
      "destination": "/services/corporate",
      "permanent": true
    },
    {
      "source": "/our-clients.html",
      "destination": "/our-clients",
      "permanent": true
    },
    {
      "source": "/testimonials.html",
      "destination": "/testimonials",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/services/corperate",
      "destination": "/services/corporate",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/services",
      "destination": "/services.html"
    },
    {
      "source": "/services/it",
      "destination": "/services/it.html"
    },
    {
      "source": "/services/bpo",
      "destination": "/services/bpo.html"
    },
    {
      "source": "/services/non-it",
      "destination": "/services/non-it.html"
    },
    {
      "source": "/services/accounting",
      "destination": "/services/accounting.html"
    },
    {
      "source": "/services/healthcare",
      "destination": "/services/healthcare.html"
    },
    {
      "source": "/services/corporate",
      "destination": "/services/corporate.html"
    },
    {
      "source": "/our-clients",
      "destination": "/our-clients.html"
    },
    {
      "source": "/testimonials",
      "destination": "/testimonials.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/404",
      "destination": "/404.html"
    }
  ],
  "trailingSlash": false,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
